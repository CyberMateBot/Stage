APP_NAMESPACE=ecom
APP_NAME=go-template
APP_ENVIRONMENT=dev
APP_IMAGE=ghcr.io/twelvepills-936/tgapp:latest
APP_SWAGGER_FILE="./api/service.swagger.json"
APP_HTTP_PORT=8090
APP_GRPC_PORT=8091
APP_LOG_LEVEL=debug

DOC_PORT=9081
JOB_PORT=8410

GOLANG_PROTOBUF_REGISTRATION_CONFLICT=warn

TELEMETRY_LOGGER_DISABLE=true
TELEMETRY_METRIC_DISABLE=true
TELEMETRY_TRACING_DISABLE=true

PG_USER=postgres
PG_PASSWORD=postgres
PG_HOST=localhost
PG_PORT=5432
PG_DBNAME=postgres

# Railway: add a Postgres plugin, then reference its variables on the app service.
# The app reads DATABASE_URL and/or PGHOST, PGPORT, PGUSER, PGPASSWORD, PGDATABASE.
# DATABASE_URL=postgresql://...
# PG_SSLMODE=require

# Telegram (@CyberMate_bot)
TELEGRAM_BOT_USERNAME=CyberMate_bot
TELEGRAM_REFERRAL_PARAM_PREFIX=ref_
TELEGRAM_SUPPORT_INVITE_URL=https://t.me/+jXI2qDR9Y-xkZTI6
# Long polling only if no webhook elsewhere (Railway: leave false)
TELEGRAM_BOT_POLLING=false
# Public HTTPS URL for bot updates (Railway): https://YOUR-BACKEND/v1/telegram/webhook
TELEGRAM_WEBHOOK_URL=
# Mini App open link (default: https://t.me/TELEGRAM_BOT_USERNAME?startapp)
TELEGRAM_MINI_APP_URL=

# CORS (production default is * if unset; or set explicitly)
CORS_ALLOWED_ORIGINS=*

# === AI generation (POST /v1/generate/text, POST /v1/generate/image) ===
YANDEX_GPT_API_KEY=
YANDEX_GPT_FOLDER_ID=
YANDEX_GPT_MODEL=yandexgpt/latest
YANDEX_DEEPSEEK_MODEL=deepseek-v32/latest
# Text models via AI Studio Responses API (ids: gpt-oss-20b, gpt-oss-120b, qwen3.6-35b, qwen3-235b)
# GET /v1/generate/models — list for frontend
YANDEX_ALICE_AI_ART_MODEL=aliceai-image-art-3.0/latest
YANDEX_IMAGE_SIZE=1024x1024
AI_TEXT_MAX_OUTPUT_TOKENS=4096
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4o-mini
WAVESPEED_API_KEY=
GEMINI_API_BASE_URL=https://llm.wavespeed.ai/v1
GEMINI_MODEL=google/gemini-2.0-flash-001
NANO_BANANA_MODEL=google/nano-banana-pro
NANO_BANANA_RESOLUTION=1k
NANO_BANANA_OUTPUT_FORMAT=jpeg
